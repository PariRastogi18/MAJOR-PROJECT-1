<% layout("/layouts/boilerplate") %>

<!-- Parent row ko center kiya aur mobile par side gaps (px-3) diye -->
<div class="row mt-3 justify-content-center px-3 px-md-0">
  <!-- Mobile par full width (col-12), tablet par thoda compact, aur desktop par perfect size -->
  <div class="col-12 col-md-8 col-lg-6">
    <div
      class="alert alert-danger alert-dismissible fade show shadow-sm d-flex align-items-center mb-0"
      role="alert"
    >
      <!-- Vibe check: Alert ko aur modern banane ke liye ek warning icon -->
      <i class="fa-solid fa-triangle-exclamation me-3 fs-5"></i>
      <div>
        <p class="alert-heading mb-0 fw-medium"><%= message %></p>
      </div>
      <!-- Bootstrap standard close button taaki user alert ko cut kar sake -->
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
  </div>
</div>
