<style>
  /* Elements collision rokne ke liye clearance spacing wrapper */
  .top-controls-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-top: 1rem;
    width: 100%;
    clear: both; /* Floating items spacing safety */
  }

  #filters {
    display: flex;
    align-items: center;
    overflow-x: auto;
    white-space: nowrap;
    padding: 0.5rem 0;
    -webkit-overflow-scrolling: touch;
    width: 100%;
  }

  #filters::-webkit-scrollbar {
    display: none;
  }

  .filter {
    text-align: center;
    margin-right: 1.5rem;
    opacity: 0.7;
    cursor: pointer;
    display: inline-block;
    flex-shrink: 0;
  }

  .filter p {
    font-size: 0.75rem;
    margin-bottom: 0;
    margin-top: 0.3rem;
  }

  /* Fixed Custom CSS Tax Container for No Borders break out */
  .tax-toggle {
    border: 1px solid #dcdcdc;
    border-radius: 12px;
    height: 3.5rem;
    padding: 0 1.2rem;
    display: flex;
    align-items: center;
    background-color: #ffffff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
    width: 100%;
    box-sizing: border-box;
  }

  .tax-toggle .form-switch {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-left: 0;
  }

  .tax-toggle .form-check-label {
    font-size: 0.88rem;
    color: #484848;
    cursor: pointer;
  }

  .tax-toggle .form-check-input {
    margin: 0;
    cursor: pointer;
    height: 1.4rem;
    width: 2.5rem;
  }

  .tax-info {
    display: none;
  }

  /* Media Queries for Desktop and Tablets */
  @media (min-width: 768px) {
    .top-controls-wrapper {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-top: 1.5rem;
    }
    .tax-toggle {
      width: auto;
      border: 2px solid black;
      border-radius: 10px;
      box-shadow: none;
    }
  }
</style>

<div class="top-controls-wrapper">
  <!-- Horizontal Scrollable Filters -->
  <div id="filters">
    <a
      href="/listings?category=trending"
      class="filter <%= typeof category !== 'undefined' && category === 'trending' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a
      href="/listings?category=rooms"
      class="filter <%= typeof category !== 'undefined' && category === 'rooms' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a
      href="/listings?category=iconicCities"
      class="filter <%= typeof category !== 'undefined' && category === 'iconicCities' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a
      href="/listings?category=mountains"
      class="filter <%= typeof category !== 'undefined' && category === 'mountains' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a
      href="/listings?category=castles"
      class="filter <%= typeof category !== 'undefined' && category === 'castles' ? 'active' : '' %>"
    >
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </a>
    <a
      href="/listings?category=amazingPools"
      class="filter <%= typeof category !== 'undefined' && category === 'amazingPools' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
    </a>
    <a
      href="/listings?category=camping"
      class="filter <%= typeof category !== 'undefined' && category === 'camping' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
    <a
      href="/listings?category=farms"
      class="filter <%= typeof category !== 'undefined' && category === 'farms' ? 'active' : '' %>"
    >
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </a>
    <a
      href="/listings?category=arctic"
      class="filter <%= typeof category !== 'undefined' && category === 'arctic' ? 'active' : '' %>"
    >
      <div><i class="fa-regular fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
  </div>

  <!-- Corrected Tax Toggle Switch Module Inside Box bounds -->
  <div class="tax-toggle">
    <div class="form-check form-switch">
      <label class="form-check-label fw-medium" for="switchCheckDefault"
        >Display total before taxes</label
      >
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      />
    </div>
  </div>
</div>
