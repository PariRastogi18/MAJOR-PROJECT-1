<% layout("/layouts/boilerplate") %>
  <style>
    /* Filters Container Rules */
    #filters {
      display: flex;
      align-items: center;
      overflow-x: auto; /* Mobile par swipe/scroll hone ke liye */
      white-space: nowrap;
      padding: 0.5rem 0;
      -webkit-overflow-scrolling: touch;
    }
    
    /* Hide Scrollbar for Chrome, Safari and Opera */
    #filters::-webkit-scrollbar {
      display: none;
    }

    /* Hide Scrollbar for IE, Edge and Firefox */
    #filters {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }

    .filter {
      margin-top: 1rem;
      text-align: center;
      margin-right: 1.5rem; /* Margins thode kam kiye responsive ke liye */
      opacity: 0.7;
      cursor: pointer;
      display: inline-block;
      flex-shrink: 0; /* Elements compress na ho scroll bar me */
    }

    a {
      text-decoration: none;
      color: black;
    }

    .filter:hover {
      opacity: 1;
    }

    .filter p {
      font-size: 0.75rem; /* Text size thoda optimal kiya */
      margin-bottom: 0.5rem;
    }

    .tax-info {
      display: none;
    }

    /* Responsive Tax Toggle styling */
    .tax-toggle {
      border: 2px solid black;
      border-radius: 10px;
      height: 3.5rem;
      padding: 1rem;
      margin-left: 0; /* Mobile default */
      display: flex;
      align-items: center;
    }

    .filter.active {
      color: #fe424d;
      opacity: 1;
      border-bottom: 3px solid #fe424d;
    }

    .filter.active i {
      color: #fe424d;
    }

    .filter.active p {
      font-weight: 600;
    }

    /* Media Queries for Desktop and Tablets */
    @media (min-width: 768px) {
      .filter {
        margin-top: 2rem;
        margin-right: 2rem;
      }
      .filter p {
        font-size: 0.8rem;
      }
      .tax-toggle {
        margin-left: 5rem; /* Desktop par side shift */
      }
    }
  </style>

  <div id="filters">
    <a href="/listings?category=trending" class="filter <%= category === 'trending' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>

    <a href="/listings?category=rooms" class="filter <%= category === 'rooms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>

    <a href="/listings?category=iconicCities" class="filter <%= category === 'iconicCities' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>

    <a href="/listings?category=mountains" class="filter <%= category === 'mountains' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>

    <a href="/listings?category=castles" class="filter <%= category === 'castles' ? 'active' : '' %>">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </a>

    <a href="/listings?category=amazingPools" class="filter <%= category === 'amazingPools' ? 'active' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
    </a>

    <a href="/listings?category=camping" class="filter <%= category === 'camping' ? 'active' : '' %>">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>

    <a href="/listings?category=farms" class="filter <%= category === 'farms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </a>

    <a href="/listings?category=arctic" class="filter <%= category === 'arctic' ? 'active' : '' %>">
      <div><i class="fa-regular fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
  </div>

  <!-- Cards Section Grid optimized for Mobile, Tablet and Desktop -->
  <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
      <div class="col-12 col-md-6 col-lg-4 mb-4">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card h-100 listing-card border-0">
            <img src="<%= listing.image.url %>" class="card-img-top img-fluid rounded-3" alt="listing_image" style="height: 20rem; object-fit: cover;">
            <div class="card-img-overlay"></div>
            <div class="card-body px-0">
              <b class="card-text"><%= listing.title %></b>
              <p class="card-text">₹ <%= listing.price.toLocaleString("en-IN") %>/night</p>
              <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    // Added safety check in case switchCheckDefault doesn't exist on this exact page view
    if(taxSwitch) {
      taxSwitch.addEventListener("click",()=>{
        let taxInfo = document.getElementsByClassName("tax-info");
        for(let info of taxInfo){
          if(info.style.display != "inline"){
            info.style.display = "inline";
          } else {
            info.style.display = "none";
          }
        }
      });
    }
  </script>
